# Required
ANTHROPIC_API_KEY=sk-ant-...          # The Watchman (Claude Sonnet)
VOYAGER_PATH=/Users/.../Voyager       # Path to Voyager repo
RESEND_API_KEY=re_...                 # Email delivery (Resend)
NOTIFICATION_EMAIL=you@example.com    # Where to send digests

# Cloud deployment (optional, for Vercel)
TURSO_DATABASE_URL=libsql://...       # Turso cloud DB
TURSO_AUTH_TOKEN=...                  # Turso auth token
CLERK_SECRET_KEY=...                  # Auth for cloud UI
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=... # Clerk frontend key

# Auto-detected (no config needed)
# Gemini CLI: uses ~/.config/gemini/ credentials
# Claude CLI: uses ~/.claude/ credentials
